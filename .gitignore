claude/backups/
claude/cache/
claude/daemon*
claude/debug/
claude/downloads/
claude/file-history/
claude/history.jsonl
claude/ide/
claude/jobs/
claude/mcp-needs-auth-cache.json
claude/plans/
claude/plugins/
claude/projects/
claude/session-env/
claude/sessions/
claude/shell-snapshots/
