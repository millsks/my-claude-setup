# Pixi — ignore runtime env but keep project config
.pixi/
!.pixi/config.toml

# macOS
.DS_Store

# Backup files produced by sync-out
*.bak
*~

# Sensitive / machine-local Claude settings — never commit
claude/settings.local.json

